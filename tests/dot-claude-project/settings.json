{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "prompt",
            "prompt": "Check if this bash command is safe to run"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "type": "command",
        "command": "echo post-tool-use"
      }
    ]
  }
}
